# ═══════════════════════════════════════════════════
# LensAI — Environment Variables Example
# ═══════════════════════════════════════════════════
# Kopyala: cp .env.example .env.local
# Sonra .env.local içindeki değerleri doldur
# ASLA .env.local veya .env dosyasını commit etme!
# ═══════════════════════════════════════════════════

# ───────────────────────────────────────
# UYGULAMA GENEL
# ───────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
AI_SERVICE_URL=http://localhost:8000
NOTIFICATION_SERVICE_URL=http://localhost:3003
ANALYTICS_SERVICE_URL=http://localhost:3004
APP_VERSION=0.1.0
LOG_LEVEL=debug

# ───────────────────────────────────────
# CLERK AUTHENTICATION
# Dashboard: https://dashboard.clerk.com
# ───────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ───────────────────────────────────────
# POSTGRESQL
# Local: docker compose up -d postgres
# ───────────────────────────────────────
DATABASE_URL=postgresql://lensai:lensai_password@localhost:5432/lensai_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_SSL=false

# ───────────────────────────────────────
# MONGODB
# Local: docker compose up -d mongodb
# ───────────────────────────────────────
MONGODB_URI=mongodb://lensai:lensai_password@localhost:27017/lensai_dev?authSource=admin
MONGODB_DB_NAME=lensai_dev

# ───────────────────────────────────────
# REDIS
# Local: docker compose up -d redis
# ───────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false

# ───────────────────────────────────────
# PINECONE (Vektör DB)
# https://app.pinecone.io
# ───────────────────────────────────────
PINECONE_API_KEY=REPLACE_ME
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=lensai-styles

# ───────────────────────────────────────
# OPENAI
# https://platform.openai.com/api-keys
# ───────────────────────────────────────
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_ORG_ID=org-REPLACE_ME
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# ───────────────────────────────────────
# KLING AI (Primary Video Generation)
# https://klingai.com/
# ───────────────────────────────────────
KLING_API_KEY=REPLACE_ME
KLING_API_URL=https://api.klingai.com
KLING_TIMEOUT_MS=300000

# ───────────────────────────────────────
# RUNWAY (Fallback Video)
# https://runwayml.com/
# ───────────────────────────────────────
RUNWAY_API_KEY=REPLACE_ME
RUNWAY_API_URL=https://api.runwayml.com
RUNWAY_TIMEOUT_MS=300000

# ───────────────────────────────────────
# LUMA DREAM MACHINE (Alt Video)
# https://lumalabs.ai/
# ───────────────────────────────────────
LUMA_API_KEY=REPLACE_ME
LUMA_API_URL=https://api.lumalabs.ai

# ───────────────────────────────────────
# REMOVE.BG (Maskeleme)
# https://www.remove.bg/api
# ───────────────────────────────────────
REMOVEBG_API_KEY=REPLACE_ME
REMOVEBG_API_URL=https://api.remove.bg/v1.0

# ───────────────────────────────────────
# STABILITY AI
# https://stability.ai/
# ───────────────────────────────────────
STABILITY_API_KEY=REPLACE_ME
STABILITY_API_URL=https://api.stability.ai

# ───────────────────────────────────────
# REPLICATE (Faz 3'te aktif)
# https://replicate.com/
# ───────────────────────────────────────
REPLICATE_API_TOKEN=REPLACE_ME

# ───────────────────────────────────────
# STRIPE
# https://dashboard.stripe.com/apikeys
# ───────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
STRIPE_PRICE_FREE=price_REPLACE_ME
STRIPE_PRICE_STARTER=price_REPLACE_ME
STRIPE_PRICE_PRO=price_REPLACE_ME
STRIPE_PRICE_AGENCY=price_REPLACE_ME

# ───────────────────────────────────────
# AWS
# IAM User: lensai-app (programmatic access)
# ───────────────────────────────────────
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
S3_BUCKET_UPLOADS=lensai-uploads-dev
S3_BUCKET_VIDEOS=lensai-videos-dev
S3_BUCKET_ASSETS=lensai-assets-dev
S3_PRESIGNED_URL_EXPIRES=900
CLOUDFRONT_DISTRIBUTION_ID=REPLACE_ME
CLOUDFRONT_DOMAIN=cdn-dev.lensai.io

# ───────────────────────────────────────
# SENTRY (staging ve production'da doldur)
# https://sentry.io/
# ───────────────────────────────────────
SENTRY_DSN=REPLACE_ME
SENTRY_ENVIRONMENT=development

# ───────────────────────────────────────
# DATADOG (staging ve production'da doldur)
# ───────────────────────────────────────
DD_API_KEY=REPLACE_ME
DD_APP_KEY=REPLACE_ME
DD_SERVICE_NAME=lensai-api

# ───────────────────────────────────────
# POSTHOG (Product Analytics)
# https://app.posthog.com/
# ───────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_REPLACE_ME
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ───────────────────────────────────────
# RESEND (Email)
# https://resend.com/
# ───────────────────────────────────────
RESEND_API_KEY=re_REPLACE_ME
RESEND_FROM_EMAIL=noreply@lensai.io

# ───────────────────────────────────────
# SLACK (Alerting - staging+prod)
# ───────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE_ME
SLACK_CHANNEL_ALERTS=#alerts-critical

# ───────────────────────────────────────
# AI BÜTÇE LİMİTLERİ (USD)
# ───────────────────────────────────────
AI_DAILY_BUDGET_TOTAL=235
AI_DAILY_BUDGET_KLING=100
AI_DAILY_BUDGET_OPENAI=20
AI_MONTHLY_BUDGET_TOTAL=6970
AI_BUDGET_WARNING_THRESHOLD=0.70
AI_BUDGET_CRITICAL_THRESHOLD=0.85
AI_BUDGET_SHUTDOWN_THRESHOLD=0.95

# ───────────────────────────────────────
# INTERNAL SERVICE AUTH
# Servisler arası iletişim için
# ───────────────────────────────────────
INTERNAL_API_SECRET=REPLACE_WITH_RANDOM_32_CHAR_STRING
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING
